			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "登录",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/maptest/maptest",
			"style": {
				"navigationBarTitleText": "地图演示"
			}
		},
		{
			"path": "pages/Mine/Mine",
			"style": {
				"navigationBarTitleText": "个人中心"
			}
		},
		{
			"path": "pages/Trip/Trip",
			"style": {
				"navigationBarTitleText": "行程"
			}
		},
		{
			"path": "pages/TripDetails/TripDetails",
			"style": {
				"navigationBarTitleText": "行程详情"
			}
		},
		{
			"path": "pages/MyCollections/MyCollections",
